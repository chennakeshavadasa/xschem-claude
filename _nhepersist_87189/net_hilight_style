# xschem net highlight styles -- generated by the net highlight style editor.
# 8 columns per row: index color width dash angle blink_ms anim rate_persec
# (color = layer index | X color name | #rrggbb ; anim = none|march_fwd|march_rev).
set net_hilight_editor_seen 1
set net_hilight_style {{0 4 1 {} 0 0 none 0} {1 red 3 {6 4} 30 0 march_fwd 2} {2 #00ff00 2 {} 0 250 none 0}}
catch {xschem update_net_hilight_style}
