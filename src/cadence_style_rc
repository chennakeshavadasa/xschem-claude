# Cadence-style instantiation: the "i" key opens the Create Instance browser
# (Edit > Create Instance). `break` stops the event reaching the generic <KeyPress>
# -> C dispatcher, which otherwise maps 'i' to descend-into-symbol.
bind .drw <Key-i> {xschem create_instance; break}

# Cadence-style net highlighting (see specs/net_hilight_styles.md):
#   9 : highlight net. If a net/wire/label is selected, highlight it (advancing the
#       style each time, leaving the selection intact); otherwise enter highlight mode
#       and click nets/labels to highlight, ESC to end.
#   8 : remove a specific net highlight (noun-verb on the selection, or click-to-remove
#       mode otherwise).
#   0 : remove ALL net highlights.
# `break` stops the digit reaching the C dispatcher (where 0 toggles pin logic level).
bind .drw <Key-9> {xschem hilight_net_interactive;   break}
bind .drw <Key-8> {xschem unhilight_net_interactive; break}
bind .drw <Key-0> {xschem unhilight_all;             break}

# --------------------------------------------------------------------------
# Cadence-style key bindings (library navigation + hierarchy).
# See specs/cadence_bindkey_plan.md. Pure Tcl, no C changes: each bind lives on
# .drw and ends in `break`, so it captures the chord before the generic
# <KeyPress> -> C dispatcher sees it. Five of these chords are claimed by the C
# dispatcher (Save as Symbol, Clear symbol, Cut, Edit-in-new-window, Crosshair);
# the `break` overrides them. Those commands remain on their menus; optional
# replacement key bindings are listed (commented out) at the end.
# --------------------------------------------------------------------------

# Helper procs (utils/), path-resolved relative to this rc file.
set _ut [file join [file dirname [file normalize [info script]]] .. utils]
source [file join $_ut lib_mgr_helpers.tcl]
source [file join $_ut cadence_nav.tcl]
# moved unset _ut

# Ctrl-Alt-S : show the selected instance in the Library Manager
bind .drw <Control-Alt-Key-s>   {locate_selected_in_libmgr;       break}
# Ctrl-Alt-N : place the current Library-Manager selection
bind .drw <Control-Alt-Key-n>   {place_libmgr_selection;          break}
# Ctrl-Shift-N : selected instance's schematic in a NEW, read-only window
bind .drw <Control-Shift-Key-N> {cadence::open_inst_sch_readonly; break}
# Ctrl-X : descend into selected instance's schematic (no-op if none selected)
bind .drw <Control-Key-x>       {cadence::descend_into_inst;      break}
# Alt-E : return to top of hierarchy, remembering where we were (per window)
bind .drw <Alt-Key-e>           {cadence::return_to_top;          break}
# Alt-X : descend back into the location remembered by the last Alt-E
bind .drw <Alt-Key-x>           {cadence::descend_to_last;        break}
# Ctrl-2 / Ctrl-Shift-2 : make the current view Editable / Read Only.
# GOTCHA: with Shift held, the number-row "2" key emits its SHIFTED keysym, not
# "2" -- so <Control-Shift-Key-2> never matches. On a US layout Shift-2 is "@"
# (keysym "at"), so Ctrl-Shift-2 must be bound via <Control-Key-at>. The Key-2 form
# is kept as a fallback for layouts where Shift-2 stays "2". On a non-US layout
# replace "at" with whatever your Shift-2 produces (run `xev` to find the keysym).
bind .drw <Control-Key-2>       {cadence::make_editable;          break}
bind .drw <Control-Key-at>      {cadence::make_readonly;          break}
bind .drw <Control-Shift-Key-2> {cadence::make_readonly;          break}

# Descend opens the child schematic READ-ONLY by default (browse mode). To edit,
# press Ctrl-2 after descending, use the "Descend schematic (edit)" right-click
# item, or View > Toggle Read Only.
set descend_readonly 1

# --- Optional re-homes for the commands whose keys were taken above. --------
# Disabled by default (the commands stay reachable from their menus). Uncomment
# to give them a key again. Chords below were checked to be free.
#   Cut (was Ctrl-X):
# bind .drw <Alt-Shift-Key-X>         {xschem cut;              break}
#   Edit schematic in a new window (was Alt-E):
# bind .drw <Control-Shift-Key-E>     {open_sub_schematic;      break}
#   Save as Symbol (was Ctrl-Alt-S):
# bind .drw <Control-Alt-Shift-Key-S> {xschem saveas {} symbol; break}
# Clear symbol (was Ctrl-Shift-N) and Draw crosshair (was Alt-X) are left as
# menu items only (Symbol > Clear symbol; Options > Crosshair > Draw crosshair).

# --- snap / grid / highlight key actions (specs/keybind_snap_grid_actions.md) --
# These ship UNBOUND: no built-in default chord. Each is a registered action, also
# reachable from the menus (Options / View). Map any action to any chord with
#   xschem bind key <keysym> <mods> canvas <action>
# Keysyms: g=103  G=71  %=37  s=115  (run `xev` for others); mods 0|ctrl|alt|shift|super.
# GOTCHA: Shift changes the produced keysym (Shift-g -> 'G'/71), same as Ctrl-Shift-2
# above -- the examples use the actual produced keysyms.

# CTRL-G toggles grid visibility (active):
xschem bind key 103 ctrl canvas view.toggle_draw_grid

